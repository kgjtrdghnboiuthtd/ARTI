{
  "name": "arcti",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "arcti": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build --compile src/index.ts --outfile arcti",
    "server": "bun run src/index.ts --server"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "hono": "^4.12.9",
    "pino": "^10.3.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
